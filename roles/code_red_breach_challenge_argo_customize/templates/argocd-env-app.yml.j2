---
apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  annotations:
    arch.internal.io/ha-policy: active-passive-failover
    ctf.onboarding/temporary-token: l34ky_m3t4d4t4_v14_g1t0ps
    ops.internal.io/monitoring-profile: standard
  name: {{ code_red_breach_challenge_argo_customize_argo_user_name_base }}{{ index }}-env-manifests
spec:
  project: default
  source:
    repoURL: https://{{ code_red_breach_challenge_argo_customize_gitea_endpoint }}/{{
      code_red_breach_challenge_argo_customize_gitea_admin_user }}/{{ code_red_breach_challenge_argo_customize_gitea_user_name_base }}{{ index }}-env-gitops.git
    targetRevision: HEAD
    path: .
    helm:
      valuesObject:
        app:
          bastionIp: {{ _hacker_app_ip }}
  destination:
    server: https://kubernetes.default.svc
    namespace: customers-{{ code_red_breach_challenge_argo_customize_argo_user_name_base }}{{ index }}
  ignoreDifferences:
    - group: '*'
      jqPathExpressions:
        - '.imagePullSecrets[] | select(.name | contains("-dockercfg-"))'
      kind: ServiceAccount
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
    - CreateNamespace=true
    - ApplyOutOfSyncOnly=true
    retry:
      limit: -1
      backoff:
        duration: 5s # the amount to back off. Default unit is seconds, but could also be a duration (e.g. "2m", "1h")
        factor: 2 # a factor to multiply the base duration after each failed retry
        maxDuration: 2m # the maximum amount of time allowed for the backoff strategy
